  "keywords": [
    "lastdb",
    "folddb",
    "sdk",
    "consent",
    "capability",
    "local-first",
    "personal-data"
  ],
  "homepage": "https://github.com/EdgeVector/fold/tree/main/lastdb_app_sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EdgeVector/fold.git",
    "directory": "lastdb_app_sdk"
  },
  "bugs": {
    "url": "https://github.com/EdgeVector/fold/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
